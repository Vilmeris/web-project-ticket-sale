@model IEnumerable<Web_Programming_Project.Models.Ticket>

@{
    ViewBag.Title = "Biletlerim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 1. ÜST BAŞLIK ALANI */
    .top-header-section {
        background-color: #1e2024;
        color: white;
        padding: 30px 20px;
        text-align: center;
        border-radius: 0 0 15px 15px;
        margin-bottom: 30px;
        width: 100%;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .header-title {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 5px;
        color: #fff;
    }

    .header-subtitle {
        color: #aaa;
        font-size: 0.9rem;
        display: block;
        margin-bottom: 20px;
    }

    .btn-browse {
        background-color: #fff;
        color: #333;
        font-weight: 700;
        padding: 10px 30px;
        border-radius: 50px;
        text-decoration: none;
        transition: transform 0.2s ease;
        display: inline-block;
    }

    .btn-browse:hover {
        transform: scale(1.05);
        background-color: #f0f0f0;
        color: #000;
        text-decoration: none;
    }

    /* 2. GRID YAPISI (5 SÜTUNLU YAPI - CSS GRID) */
    .custom-ticket-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr); 
        gap: 20px; 
        padding: 0 20px;
        width: 100%;
    }

    
    @@media (max-width: 1600px) {
        .custom-ticket-grid { grid-template-columns: repeat(4, 1fr); }
    }
    @@media (max-width: 1200px) {
        .custom-ticket-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 992px) {
        .custom-ticket-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 576px) {
        .custom-ticket-grid { grid-template-columns: repeat(1, 1fr); }
    }


    /* 3. BİLET KARTI TASARIMI */
    .ticket-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        padding: 0; 
        text-align: center;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .ticket-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        border-color: #ccc;
    }

    /* Görsel Alanı */
    .ticket-img-container {
        width: 100%;
        height: 150px;
        background-color: #f1f3f5;
        overflow: hidden;
        border-bottom: 1px solid #f0f0f0;
    }

    .ticket-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .ticket-card:hover .ticket-img {
        transform: scale(1.05);
    }

    /* İçerik Alanı */
    .card-content {
        padding: 15px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .event-title {
        font-size: 1rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
        line-height: 1.3;
        /* Uzun başlıkları kısaltma */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 2.6em; /* 2 satır yüksekliği */
    }

    /* Bilgi Satırları */
    .ticket-info {
        font-size: 0.8rem;
        color: #666;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
    }
    .ticket-info i { margin-right: 5px; color: #999; }

    /* Fiyat */
    .ticket-price {
        font-size: 1.1rem;
        font-weight: bold;
        color: #28a745;
        margin: 10px 0;
    }

    /* Buton */
    .card-actions {
        padding: 10px 15px;
        background-color: #f8f9fa;
        border-top: 1px solid #eee;
    }

    .btn-detail {
        display: block;
        width: 100%;
        padding: 8px 0;
        font-size: 0.85rem;
        border-radius: 6px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        font-weight: 600;
        transition: background 0.3s;
    }
    .btn-detail:hover {
        background-color: #0056b3;
        color: white;
        text-decoration: none;
    }

    /* Boş Durum */
    .empty-state {
        text-align: center;
        padding: 50px;
        width: 100%;
        color: #666;
    }

</style>

@* --- 1. ÜST KISIM (BAŞLIK) --- *@
<div class="container-fluid p-0">
    <div class="top-header-section">
        <h2 class="header-title">Biletlerim</h2>
        @if (Model != null)
        {
            <span class="header-subtitle">Sayın @ViewBag.UserName, toplam @Model.Count() adet biletiniz bulunmaktadır.</span>
        }
        else
        {
            <span class="header-subtitle">Sayın @ViewBag.UserName, biletiniz bulunmamaktadır.</span>
        }

        <a href="@Url.Action("Index", "Home")" class="btn-browse">
            Etkinlikleri Keşfet
        </a>
    </div>
</div>

@* --- 2. BİLET KARTLARI) --- *@
<div class="container-fluid mb-5">

    @if (Model != null && Model.Count() > 0)
    {
        <div class="custom-ticket-grid">
            @foreach (var ticket in Model)
            {
                <div class="ticket-card">

                    @* Görsel *@
                    <div class="ticket-img-container">
                        <img src="@((ticket.Event != null && !string.IsNullOrEmpty(ticket.Event.ImageUrl)) ? ticket.Event.ImageUrl : "https://via.placeholder.com/300x150")"
                             class="ticket-img"
                             alt="Etkinlik Görseli">
                    </div>

                    @* İçerik *@
                    <div class="card-content">
                        <div class="event-title" title="@(ticket.Event != null ? ticket.Event.Title : "")">
                            @(ticket.Event != null ? ticket.Event.Title : "Etkinlik Silinmiş")
                        </div>

                        <div class="ticket-info">
                            <i>📅</i> @ticket.PurchaseDate.ToString("dd.MM.yyyy HH:mm")
                        </div>

                        <div class="ticket-info">
                            <i>💺</i> Koltuk: <strong>@ticket.SeatNumber</strong>
                        </div>

                        <div class="ticket-price">
                            @ticket.PricePaid.ToString("C2")
                        </div>
                    </div>

                    @* Aksiyon Butonu *@
                    @if (ticket.Event != null)
                    {
                        <div class="card-actions">
                            <a href="@Url.Action("Details", "Home", new { id = ticket.EventId })" class="btn-detail">
                                ETKİNLİĞE GİT
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <h4>Henüz satın aldığınız bir bilet yok.</h4>
            <p>Yukarıdaki butona tıklayarak etkinliklere göz atabilirsiniz.</p>
        </div>
    }
</div>