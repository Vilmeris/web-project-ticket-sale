@model List<Web_Programming_Project.Models.CartItem>

@{
    ViewBag.Title = "Alışveriş Sepetim";
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal grandTotal = 0;
}

<div class="container my-5">
    <h2 class="mb-4 fw-bold">🛒 Alışveriş Sepetim</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning text-center p-5">
            <h4>Sepetinizde henüz bilet bulunmamaktadır.</h4>
            <p>Etkinliklere göz atıp hemen bilet alabilirsiniz.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-3">Etkinlikleri Keşfet</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Etkinlik</th>
                                    <th>Tarih</th>
                                    <th>Fiyat</th>
                                    <th>Koltuk</th>
                                    <th>Toplam</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    grandTotal += item.TotalPrice;
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.Event.ImageUrl))
                                                {
                                                    <img src="@item.Event.ImageUrl" alt="img" style="width: 100px; height: 100px; object-fit: cover; border-radius: 5px; margin-right: 10px;" />
                                                }
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@item.Event.Title</h6>
                                                    <small class="text-muted">@item.Event.Category</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @item.Event.Date.ToString("dd.MM.yyyy")<br />
                                            <small class="text-muted">@item.Event.Date.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            @if (item.Event.DiscountRate > 0)
                                            {
                                                <span class="text-decoration-line-through text-muted small">@item.Event.Price.ToString("C0")</span><br />
                                                <span class="text-success fw-bold">@item.Event.DiscountedPrice.ToString("C0")</span>
                                            }
                                            else
                                            {
                                                <span>@item.Event.Price.ToString("C0")</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-info text-dark">@item.SeatNumber</span>
                                        </td>
                                        <td class="fw-bold text-primary">
                                            @item.TotalPrice.ToString("C2")
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Remove", "Cart", new { eventId = item.Event.EventId, seatNumber = item.SeatNumber })"
                                               class="btn btn-sm btn-outline-danger" title="Sil">
                                                🗑️
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-3">
                    <a href="@Url.Action("ClearCart", "Cart")" class="text-danger small text-decoration-none">⚠️ Sepeti Temizle</a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4">Sipariş Özeti</h5>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Ara Toplam</span>
                            <span>@grandTotal.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Hizmet Bedeli</span>
                            <span>₺0,00</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <strong class="fs-5">Genel Toplam</strong>
                            <strong class="fs-5 text-success">@grandTotal.ToString("C2")</strong>
                        </div>
                        <form action="@Url.Action("Checkout", "Cart")" method="post">
                            <button class="btn btn-success w-100 py-2 fw-bold shadow-sm">
                                💳 Ödemeyi Tamamla
                            </button>
                        </form>
                            <a href="@Url.Action("Index", "Home")" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">
                                ← Alışverişe Devam Et
                            </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

