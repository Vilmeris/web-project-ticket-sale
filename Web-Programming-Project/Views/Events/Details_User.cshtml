@model Web_Programming_Project.Models.Event

@{
    ViewBag.Title = Model.Title + " | Detaylar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section head {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <style>
        /* Layout Sıfırlama */
        body, html { margin: 0; padding: 0; height: 100%; overflow-x: hidden; }

        /* ARKA PLAN (Flu Görüntü) */
        .page-bg-layer {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('@Model.ImageUrl');
            background-size: cover; background-position: center;
            filter: blur(40px) brightness(0.5); z-index: -2;
        }

        /* === MASAÜSTÜ TAM EKRAN DÜZENİ === */
        @@media (min-width: 992px) {
            .fullscreen-wrapper {
                position: relative;
                width: 100vw;
                height: 1500px;
                background: #fff;
                overflow: hidden;
                display: flex;
            }

            /* --- SOL PANEL --- */
            .left-panel {
                position: relative;
                width: 60%;
                height: 100%;
                background: #000;
            }

            .image-area {
                position: absolute; top: 0; left: 0; width: 100%; height: 55vh; overflow: hidden;
            }

            .countdown-strip {
                position: absolute; top: 55vh; left: 0; width: 100%; height: 70px;
                background: #111; color: #ffc107;
                display: flex; align-items: center; justify-content: center;
                gap: 50px; z-index: 10; border-bottom: 1px solid #333;
            }

            .text-scroll-area {
                position: absolute; top: calc(55vh + 70px); left: 0; width: 100%; bottom: 0;
                padding: 40px 60px; background: #fff; overflow-y: auto;
            }

            /* --- SAĞ PANEL --- */
            .right-panel {
                width: 40%;
                height: 100%;
                background: #f8f9fa;
                border-left: 1px solid #ddd;
                padding: 30px;
                display: flex;
                flex-direction: column;
                overflow-y: auto;
                box-shadow: -5px 0 20px rgba(0,0,0,0.05);
                z-index: 20;
            }

            .back-btn-floating {
                position: absolute; top: 30px; left: 30px; z-index: 100;
                background: rgba(0,0,0,0.6); color: #fff; padding: 10px 20px;
                border-radius: 30px; text-decoration: none; font-weight: bold;
                backdrop-filter: blur(5px); transition: 0.3s;
            }
            .back-btn-floating:hover { background: #d71920; color: #fff; }
        }

        /* ORTAK STİLLER */
        .event-image { width: 100%; height: 100%; object-fit: cover; object-position: center top; transition: 1s ease; }
        .image-area:hover .event-image { transform: scale(1.05); }
        .count-item span { font-size: 1.5rem; font-weight: 800; display: block; line-height: 1; }
        .count-item small { font-size: 0.75rem; color: #999; letter-spacing: 1px; text-transform: uppercase; }

        /* TABS */
        .nav-tabs { border-bottom: 2px solid #eee; margin-bottom: 30px; }
        .nav-link { color: #888; border: none !important; font-size: 1.1rem; font-weight: 600; padding: 10px 20px; }
        .nav-link.active { color: #d71920; border-bottom: 3px solid #d71920 !important; background: none; }

        /* SAĞ PANEL BİLEŞENLERİ */
        .badge-cat { background: #ffc107; color: #000; padding: 5px 15px; border-radius: 20px; font-weight: 800; letter-spacing: 0.5px; }
        .event-title { font-size: 2.5rem; font-weight: 900; line-height: 1.1; margin: 15px 0 5px; color: #222; }
        .artist-title { font-size: 1.1rem; color: #d71920; font-weight: 700; margin-bottom: 20px; }

        .info-row { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; padding: 12px; background: #fff; border: 1px solid #eee; border-radius: 12px; }
        .icon-box { width: 40px; height: 40px; background: #fff5f5; color: #d71920; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }

        /* BİLET LİSTESİ STİLİ */
        .ticket-category-card {
            background: #fff; border: 1px solid #ddd; border-radius: 12px;
            padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between;
            align-items: center; cursor: pointer; transition: 0.2s;
        }
        .ticket-category-card:hover { border-color: #d71920; background: #fff9f9; }
        .ticket-category-card.selected { border: 2px solid #d71920; background: #fff0f0; }

        /* Satın Al Butonu */
        .buy-btn { background: linear-gradient(90deg, #d71920, #b00e15); color: #fff; display: block; width: 100%; padding: 18px; border-radius: 12px; font-weight: 800; font-size: 1.2rem; text-decoration: none; transition: 0.3s; margin-top: 20px; text-align: center; }
        .buy-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(215, 25, 32, 0.4); color: #fff; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
    </style>
}

<div class="page-bg-layer"></div>

<div class="fullscreen-wrapper">

    <a href="@Url.Action("Index", "Home")" class="back-btn-floating">
        <i class="fa fa-arrow-left me-2"></i> Listeye Dön
    </a>

    <div class="left-panel">
        <div class="image-area">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="event-image" alt="@Model.Title" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center h-100 bg-dark text-white fs-3">Görsel Yok</div>
            }
        </div>

        <div class="countdown-strip" id="countdown"></div>

        <div class="text-scroll-area">
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#desc">Etkinlik Hakkında</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#rules">Sanatçı & Kurallar</button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="desc">
                    <h3 class="fw-bold text-dark mb-4">Detaylar</h3>
                    <p class="fs-5 text-muted" style="line-height: 1.9;">@Model.Description</p>
                    <div class="alert alert-light border mt-4">
                        <i class="fa fa-info-circle text-primary me-2"></i>
                        Kapı açılış: Etkinlik saatinden 1 saat önce.
                    </div>
                </div>

                <div class="tab-pane fade" id="rules">
                    <h3 class="fw-bold text-dark mb-4">Kurallar</h3>
                    <ul class="list-unstyled fs-5 text-muted">
                        <li class="mb-3"><i class="fa fa-check-circle text-success me-2"></i> 18 yaş sınırı vardır.</li>
                        <li class="mb-3"><i class="fa fa-ban text-danger me-2"></i> Profesyonel kamera yasaktır.</li>
                        <li class="mb-3"><i class="fa fa-times-circle text-danger me-2"></i> Bilet iadesi yoktur.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="right-panel">

        <div>
            <span class="badge-cat">@Model.Category</span>
            <h1 class="event-title">@Model.Title</h1>
            <div class="artist-title"><i class="fa fa-microphone-alt me-2"></i> @Model.Artist</div>
        </div>

        <div class="info-row">
            <div class="icon-box"><i class="fa fa-calendar-alt"></i></div>
            <div>
                <div class="small text-muted fw-bold ls-1">TARİH</div>
                <div class="fw-bold text-dark">@Model.Date.ToString("dd MMMM yyyy, HH:mm")</div>
            </div>
        </div>

        <div class="info-row mb-2">
            <div class="icon-box"><i class="fa fa-map-location-dot"></i></div>
            <div>
                <div class="small text-muted fw-bold ls-1">MEKAN</div>
                <div class="fw-bold text-dark">@Model.Venue, @Model.City</div>
                <a href="https://www.google.com/maps/search/?api=1&query=@Model.Venue+@Model.City" target="_blank">
                    <div class="small text-muted fw-bold ls-1">Haritalar</div>
                </a>
            </div>
        </div>

        <br /><br /><br /><br /><br /><br /><br /><br />

        <h5 class="fw-bold mb-3"><i class="fa fa-ticket-alt me-2 text-muted"></i>Bilet Kategorisi Seç</h5>

        @{
            // VERİTABANINDAN FİYATLARI ÇEKİYORUZ
            var prices = ViewBag.PriceOptions as List<Web_Programming_Project.Models.EventPrice>;
            bool firstItem = true;
        }

        @if (prices != null && prices.Count > 0)
        {
            // EĞER VERİTABANINDA ÖZEL FİYAT VARSA DÖNGÜYE GİR
            foreach (var item in prices)
            {
                // İlk elemanı seçili (selected) yapıyoruz
                string activeClass = firstItem ? "selected" : "";
                string checkStatus = firstItem ? "checked" : "";

                <label class="ticket-category-card @activeClass">
                    <div class="d-flex align-items-center">
                        <input type="radio" name="ticketType" value="@item.ZoneName" @checkStatus class="form-check-input me-3" style="width: 20px; height: 20px;">
                        <div>
                            <div class="fw-bold text-dark">@item.ZoneName</div>
                            <small class="text-muted">Kişi Başı</small>
                        </div>
                    </div>
                    <div class="fw-bold fs-5">@item.Price.ToString("C2")</div>
                </label>

                firstItem = false;
            }
        }
        else
        {
            // EĞER FİYAT LİSTESİ BOŞSA VARSAYILAN STANDART FİYATI GÖSTER
            <label class="ticket-category-card selected">
                <div class="d-flex align-items-center">
                    <input type="radio" name="ticketType" value="Standart" checked class="form-check-input me-3" style="width: 20px; height: 20px;">
                    <div>
                        <div class="fw-bold text-dark">Standart Bilet</div>
                        <small class="text-muted">Genel Giriş</small>
                    </div>
                </div>
                <div class="fw-bold fs-5">@Model.Price.ToString("C2")</div>
            </label>
        }

        @if (Model.SoldTicketCount < Model.Capacity)
        {
            // === BİLET VARSA ===
            if (Model.Category == "Sinema" || Model.Category == "Tiyatro")
            {
                // SENARYO A: Koltuk Seçimi (Map)
                <div class="d-flex align-items-center gap-2 mt-3">
                    <div class="input-group" style="width: 130px;">
                        <span class="input-group-text bg-white text-muted border-end-0">x</span>
                        <input type="number" id="seatQuantity" class="form-control text-center fw-bold border-start-0" value="1" min="1" max="10">
                    </div>

                    <a href="javascript:void(0);" onclick="goToSeatMap()" class="buy-btn shadow m-0 flex-grow-1">
                        KOLTUK SEÇ & AL <i class="fa fa-arrow-right ms-2"></i>
                    </a>
                </div>

                <script>
                    function goToSeatMap() {
                        var qtyInput = document.getElementById("seatQuantity");
                        var qty = qtyInput ? qtyInput.value : 1;
                        if(qty < 1) qty = 1;
                        // URL oluştur
                        var url = '@Url.Action("SeatSelection", "Events", new { id = Model.EventId })' + '?quantity=' + qty;
                        window.location.href = url;
                    }
                </script>
            }
            else
            {
                // SENARYO B: Doğrudan Sepete Ekle (Konser vb.)
                <div class="d-flex align-items-center gap-2 mt-3">
                    <div class="input-group" style="width: 130px;">
                        <span class="input-group-text bg-white text-muted border-end-0">x</span>
                        <input type="number" id="ticketQuantity" class="form-control text-center fw-bold border-start-0" value="1" min="1" max="10">
                    </div>

                    <a href="javascript:void(0);" onclick="buyDirectly()" class="buy-btn shadow m-0 flex-grow-1">
                        SEPETE EKLE <i class="fa fa-check ms-2"></i>
                    </a>
                </div>

                <script>
                    function buyDirectly() {
                        // Seçili olan radio butonunu bul (name="ticketType")
                        var selectedRadio = document.querySelector('input[name="ticketType"]:checked');
                        var qtyInput = document.getElementById("ticketQuantity");
                        var qty = qtyInput ? qtyInput.value : 1;

                        if (selectedRadio) {
                            var categoryName = selectedRadio.value;
                            if(qty < 1) qty = 1;

                            // URL oluştur: SelectedCategory dinamik olarak radio butonundan gelir
                            var url = '@Url.Action("Payment", "Events")' +
                                      '?eventId=@Model.EventId' +
                                      '&ticketType=' + encodeURIComponent(categoryName) +
                                      '&quantity=' + qty;

                            window.location.href = url;
                        } else {
                            alert("Lütfen bir bilet türü seçiniz.");
                        }
                    }
                </script>
            }
        }
        else
        {
            // === BİLET TÜKENDİYSE ===
            <button class="buy-btn" disabled style="background:#e9ecef; color:#adb5bd; box-shadow:none; cursor:not-allowed;">
                TÜKENDİ
            </button>
        }

        <div class="text-center mt-3 text-muted small">
            <i class="fa fa-lock me-1"></i> Güvenli Ödeme
        </div>

    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        
        document.querySelectorAll('.ticket-category-card').forEach(card => {
            card.addEventListener('click', function() {
                // Hepsinden seçimi kaldır
                document.querySelectorAll('.ticket-category-card').forEach(c => c.classList.remove('selected'));
                // Radyo butonlarını temizle (görsel olarak)
                // (Normalde label click inputu tetikler ama class eklemek için bu js gerekli)
                var radio = this.querySelector('input[type="radio"]');
                if(radio) radio.checked = true;

                // Seçileni işaretle
                this.classList.add('selected');
            });
        });

        // Countdown (Geri Sayım)
        var eventDate = new Date("@Model.Date.ToString("yyyy-MM-ddTHH:mm:ss")").getTime();
        var x = setInterval(function() {
            var now = new Date().getTime();
            var distance = eventDate - now;
            if (distance < 0) {
                clearInterval(x);
                var el = document.getElementById("countdown");
                if(el) el.innerHTML = "<span class='fw-bold fs-4'>ETKİNLİK BAŞLADI!</span>";
                return;
            }
            var d = Math.floor(distance / (1000 * 60 * 60 * 24));
            var h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            var m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            var s = Math.floor((distance % (1000 * 60)) / 1000);

            var el = document.getElementById("countdown");
            if(el) {
                el.innerHTML =
                    `<div class="count-item"><span>${d}</span><small>GÜN</small></div>` +
                    `<div class="count-item"><span>${h}</span><small>SAAT</small></div>` +
                    `<div class="count-item"><span>${m}</span><small>DK</small></div>` +
                    `<div class="count-item"><span>${s}</span><small>SN</small></div>`;
            }
        }, 1000);
    </script>
}