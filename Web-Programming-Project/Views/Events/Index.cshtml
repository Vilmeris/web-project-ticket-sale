@model IEnumerable<Web_Programming_Project.Models.Event>

@{
    ViewBag.Title = "Etkinlik Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="@Url.Content("~/Content/CreateStyles.css")" rel="stylesheet" type="text/css" />

<div class="container admin-card" style="margin-top: 30px; margin-bottom: 50px; padding: 20px; border-radius: 15px;">
    <div class="d-flex justify-content-between align-items-center mb-4" style="border-bottom: 2px solid #ddd; padding-bottom: 15px;">
        <h2 class="page-title" style="font-weight: bold;">📅 Etkinlik Yönetimi</h2>
        <br />
        @Html.ActionLink("+ Yeni Etkinlik Ekle", "Create", null, new { @class = "btn btn-create shadow-sm", style = "border-radius: 50px; padding: 10px 20px;" })
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle modern-table" style="box-shadow: 0 0 15px rgba(0,0,0,0.05); border-radius: 10px; overflow: hidden;">
            <thead class="thead-dark">
                <tr style="text-align: center;">
                    <th style="width: 100px;">Görsel</th>
                    <th style="text-align: left;">Etkinlik & Sanatçı</th>
                    <th>Tarih & Kategori</th>
                    <th>Konum</th>
                    <th>Fiyat & İndirim</th>
                    <th>Satış Durumu</th>
                    <th style="min-width: 240px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="vertical-align: middle; text-align: center;">
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="Event Img" style="width: 80px; height: 50px; object-fit: cover; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);" />
                            }
                            else
                            {
                                <span class="text-muted" style="font-size: 12px;">Resim Yok</span>
                            }
                        </td>

                        <td style="text-align: left;">
                            <strong class="text-primary-custom" style="font-size: 16px;">@item.Title</strong>
                            <br />
                            <small class="text-secondary-custom" style="font-weight: bold;">🎤 @item.Artist</small>
                        </td>

                        <td>
                            <span class="text-dark-custom" style="font-weight: 500;">@item.Date.ToString("dd.MM.yyyy")</span>
                            <br />
                            <small class="text-muted">@item.Date.ToString("HH:mm")</small>
                            <br />
                            <span class="badge badge-info" style="display: inline-block; margin-top: 5px; background-color: #17a2b8; color: white; padding: 5px 10px; border-radius: 12px;">@item.Category</span>
                        </td>

                        <td>
                            <span class="text-dark-custom">@item.City</span>
                            <br />
                            <small class="text-muted">@item.Venue</small>
                        </td>

                        <td>
                            @if (item.DiscountRate > 0)
                            {
                                <span style="text-decoration: line-through; color: #999; font-size: 12px;">@item.Price.ToString("C2")</span>
                                <br />
                                <strong style="color: #28a745;">@((item.Price - (item.Price * item.DiscountRate / 100)).ToString("C2"))</strong>
                                <br />
                                <span class="badge badge-danger" style="background-color: #dc3545; color: white; font-size: 10px; border-radius: 10px;">%@item.DiscountRate İndirim</span>
                            }
                            else
                            {
                                <strong class="text-dark-custom">@item.Price.ToString("C2")</strong>
                            }
                        </td>

                        <td>
                            <span style="font-weight: bold;" class="text-dark-custom">@item.SoldTicketCount</span> / <span class="text-dark-custom">@item.Capacity</span>
                            <div class="progress" style="height: 6px; width: 80%; margin: 5px auto; border-radius: 3px; background-color: #e9ecef;">
                                @{
                                    int percent = 0;
                                    if (item.Capacity > 0) { percent = (item.SoldTicketCount * 100) / item.Capacity; }
                                }
                                <div class="progress-bar bg-warning" role="progressbar" style="width: @percent%;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </td>

                        <td>
                            <div class="d-flex justify-content-center flex-wrap gap-2">


                                <a href="@Url.Action("Edit", "Events", new { id = item.EventId })"
                                   class="btn btn-sm shadow-sm text-nowrap"
                                   style="background-color: #ffd700; color: #333; font-weight: 600; border-radius: 50px; border: none; padding: 5px 10px; font-size: 13px;">
                                    ✏️ Düzenle
                                </a>

                                <a href="@Url.Action("Details", "Events", new { id = item.EventId })"
                                   class="btn btn-sm shadow-sm text-nowrap"
                                   style="background-color: #17a2b8; color: white; font-weight: 500; border-radius: 50px; border: none; padding: 5px 10px; font-size: 13px;">
                                    📄 Detay
                                </a>

                                <a href="@Url.Action("Delete", "Events", new { id = item.EventId })"
                                   class="btn btn-sm shadow-sm text-nowrap"
                                   style="background-color: #dc3545; color: white; font-weight: 500; border-radius: 50px; border: none; padding: 5px 10px; font-size: 13px;">
                                    🗑️ Sil
                                </a>

                             

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>