@model Web_Programming_Project.Models.Event

@{
    ViewBag.Title = "Satın Alma İşlemi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" style="min-height: 600px;">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white p-4 rounded-top-4">
                    <h3 class="mb-0"><i class="fa fa-shopping-cart me-2"></i> Ödeme Onayı</h3>
                </div>
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <img src="@Model.ImageUrl" style="width: 100px; height: 100px; object-fit: cover; border-radius: 10px;" class="me-4 shadow-sm" />

                        <div>
                            <h4 class="fw-bold">@Model.Title</h4>
                            <p class="text-muted mb-0"><i class="fa fa-calendar-alt me-2"></i> @Model.Date.ToString("dd MMMM yyyy, HH:mm")</p>
                            <p class="text-muted"><i class="fa fa-map-marker-alt me-2"></i> @Model.Venue</p>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="row mb-3">
                        <div class="col-6 text-muted">Bilet Tipi:</div>
                        <div class="col-6 text-end fw-bold">@ViewBag.TicketType</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6 text-muted">Adet:</div>
                        <div class="col-6 text-end fw-bold">
                            @ViewBag.Quantity x @(((decimal)ViewBag.UnitPrice).ToString("C2"))
                        </div>
                    </div>

                    <div class="alert alert-light border d-flex justify-content-between align-items-center mt-4">
                        <span class="fs-5">Toplam Tutar:</span>
                        <span class="fs-3 fw-bold text-danger">@(((decimal)ViewBag.FinalPrice).ToString("C2"))</span>
                    </div>

                    <button class="btn btn-dark w-100 py-3 fs-5 fw-bold mt-3 shadow-sm" onclick="completePayment()">
                        <i class="fa fa-credit-card me-2"></i> Ödemeyi Tamamla
                    </button>

                    <div class="text-center mt-3">
                        <a href="@Url.Action("Details", "Events", new { id = Model.EventId })" class="text-muted text-decoration-none">
                            <small>İptal et ve geri dön</small>
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function completePayment() {
       
        alert("Tebrikler! Bilet satın alma işlemi başarıyla gerçekleşti.");
        window.location.href = "/Home/Index"; 
    }
</script>