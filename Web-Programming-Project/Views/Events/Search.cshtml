@model IEnumerable<Web_Programming_Project.Models.Event>

@{
    ViewBag.Title = "Kategorik Arama Sonuçları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<link href="~/Content/Category.css" rel="stylesheet" />

<div class="category-container">

    
    <div class="text-center mb-5">
        <h1 class="category-title">Arama Sonuçları</h1>

      
        <div class="d-flex justify-content-center align-items-center gap-2 mt-2">
            @if (Model != null && Model.Any())
            {
                <span class="badge bg-success rounded-pill px-3" style="font-size: 0.9rem;">
                    @Model.Count() Etkinlik Bulundu
                </span>
            }
            else
            {
                <span class="badge bg-secondary rounded-pill px-3" style="font-size: 0.9rem;">
                    Sonuç Bulunamadı
                </span>
            }
        </div>

     
        <div class="mt-3">
            <a href="@Url.Action("Index", "Home")" class="text-decoration-none fw-bold text-muted" style="font-size: 0.9rem;">
                <i class="bi bi-arrow-left"></i> Ana Sayfaya Dön ve Tekrar Ara
            </a>
        </div>
    </div>
    <br />

    @if (Model == null || !Model.Any())
    {
      
        <div class="col-12 text-center py-5">
            <div style="font-size: 5rem; opacity: 0.3;">🔍</div>
            <h3 class="mt-3 text-muted">Aradığınız kriterlere uygun etkinlik yok.</h3>
            <p class="text-muted">Farklı bir tarih seçmeyi veya kategori değiştirmeyi deneyebilirsiniz.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-3 px-4 py-2 rounded-pill">Tüm Etkinlikleri Gör</a>
        </div>
    }
    else
    {
       
        <div class="events-grid">
            @foreach (var item in Model)
            {
                <div class="cat-card">
                  
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Title" class="cat-image" />
                    }
                    else
                    {
                        <div class="cat-image d-flex align-items-center justify-content-center bg-light text-muted" style="height: 100%;">
                            <i class="bi bi-image fs-1"></i>
                        </div>
                    }

                  
                    <div class="cat-overlay">
                        <h3 class="cat-title">@item.Title</h3>
                        <div class="cat-artist">@item.Artist</div>

                   
                        <p class="cat-desc">
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                @item.Description
                            }
                            else
                            {
                                @item.Venue @:, @item.City
                            }
                        </p>

                        <div class="cat-price">
                            @if (item.DiscountRate > 0)
                            {
                                <span>@((item.Price - (item.Price * item.DiscountRate / 100)).ToString("C0"))</span>
                            }
                            else
                            {
                                <span>@item.Price.ToString("C0")</span>
                            }
                        </div>

                        <span class="btn-detail">Bilet Al & Detaylar</span>
                    </div>

                    <a href="@Url.Action("Details", "Home", new { id = item.EventId })" class="card-link"></a>
                </div>
            }
        </div>
    }
</div>