            </div>
        </div>
    </div>

    <div class="event-card" id="event-card2">
        <div id="barisma-container" style="display:flex">
            <div class="event-img barismanco" id="barismaimg"></div>
            <div id="barisma-info">
                <h3>Barışmanço Konser</h3>
                <p>İstanbul • 12 Mart • 20:30</p>
            </div>
        </div>
    </div>

    <div class="event-card" id="event-card3">
        <div id="intergalactic-container" style="display:flex">
            <div class="event-img intergalactic" id="galacticimg"></div>
            <div id="intergalactic-info">
                <h3>intergalactic Movie</h3>
