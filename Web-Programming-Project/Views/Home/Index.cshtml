        height: 45px;
        border-radius: 50px;
        border: 2px solid transparent; /* Diğeriyle aynı kalınlıkta ama şeffaf çerçeve */
        background: #f5a623;
        color: #fff;
        cursor: pointer;
        font-weight: bold;
        font-size: 0.95rem;
