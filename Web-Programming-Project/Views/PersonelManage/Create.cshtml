@model Web_Programming_Project.Models.User

@{
    ViewBag.Title = "Yeni Kullanıcı Oluştur";
    ViewBag.GenisSayfa = true; // Layout'ta container-fluid kullanması için
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Event sayfasındaki aynı CSS dosyasını çağırıyoruz *@
<link href="@Url.Content("~/Content/CreateStyles.css")" rel="stylesheet" type="text/css" />

<div class="container-fluid my-5 wide-container">
    <div class="row justify-content-center">
        <div class="col-12">

            <div class="admin-card">

                @* --- Header Kısmı --- *@
                <div class="admin-header d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-0 fw-bold" style="letter-spacing: 1px;">YENİ KULLANICI</h4>
                        <small style="opacity: 0.7;">Personel & Kullanıcı Yönetim Paneli</small>
                    </div>
                    <div style="background: rgba(255,255,255,0.1); padding: 5px 15px; border-radius: 20px;">
                        <small>-- Admin Kayıt Modu --</small>
                    </div>
                </div>

                <div class="card-body p-5">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        <div class="form-horizontal">
                            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                         
                            <div class="section-title">
                                1. Kişisel Bilgiler
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Ad</label>
                                    @Html.EditorFor(model => model.Name, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Örn: Ahmet" } })
                                    @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger small mt-1" })
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Soyad</label>
                                    @Html.EditorFor(model => model.Surname, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Örn: Yılmaz" } })
                                    @Html.ValidationMessageFor(model => model.Surname, "", new { @class = "text-danger small mt-1" })
                                </div>
                            </div>

                            
                            <div class="section-title mt-5">
                                2. İletişim Bilgileri
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">E-Posta Adresi</label>
                                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "ornek@email.com", type = "email" } })
                                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger small mt-1" })
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Telefon Numarası</label>
                                    @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "05XX XXX XX XX" } })
                                    @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "text-danger small mt-1" })
                                </div>
                            </div>

                            <div class="section-title mt-5">
                                3. Hesap & Yetki Ayarları
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Şifre Belirle</label>
                              
                                    @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "********", type = "password" } })
                                    @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger small mt-1" })
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Kullanıcı Rolü / Yetkisi</label>
                                    @Html.EditorFor(model => model.Role, new { htmlAttributes = new { @class = "form-control modern-input", placeholder = "Örn: Admin veya User" } })
                                    @Html.ValidationMessageFor(model => model.Role, "", new { @class = "text-danger small mt-1" })
                                    <small class="text-muted">Mevcut roller: Admin, User, Editor vb.</small>
                                </div>
                            </div>

                           
                            <div class="d-flex justify-content-between align-items-center pt-4 border-top">
                                @Html.ActionLink("← Listeye Dön", "Index", null, new { @class = "ozel-panel-kutusu ozel-stil-standart", style = "text-decoration:none; font-weight:600;" })

                                <div>
                                    <button type="reset" class="btn btn-reset me-2">
                                        Temizle
                                    </button>
                                    <button type="submit" class="btn btn-create">
                                        OLUŞTUR
                                    </button>
                                </div>
                            </div>

                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>