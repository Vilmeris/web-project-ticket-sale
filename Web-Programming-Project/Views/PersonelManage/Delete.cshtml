@model Web_Programming_Project.Models.User

@{
    ViewBag.Title = "Kullanıcıyı Sil";
}

<style>
    
    .center-lock-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 20px; 
        z-index: 10; 
    }

    
    .delete-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.15); 
        overflow: hidden;
        width: 100%;
        max-width: 500px;
        border: 1px solid #e0e0e0;
    }

    
    .card-header {
        background: linear-gradient(135deg, #ff416c, #ff4b2b); 
        color: white;
        padding: 25px;
        text-align: center;
    }

        .card-header h3 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .card-header p {
            margin: 10px 0 0;
            font-size: 0.9rem;
            opacity: 0.9;
        }

    /* İÇERİK */
    .card-body {
        padding: 30px;
    }

    /* BİLGİ SATIRLARI */
    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px dashed #ddd; 
    }

        .info-row:last-of-type {
            border-bottom: none;
        }

    .info-label {
        font-weight: 600;
        color: #777;
        font-size: 0.95rem;
    }

    .info-value {
        font-weight: 600;
        color: #333;
        font-size: 1rem;
        text-align: right;
    }

    /* BUTONLAR */
    .actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn-action {
        flex: 1;
        padding: 14px;
        border-radius: 8px;
        font-weight: 700;
        text-align: center;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        text-decoration: none;
        font-size: 1rem;
        display: inline-block;
    }

    .btn-cancel {
        background-color: #f1f3f5;
        color: #495057;
    }

        .btn-cancel:hover {
            background-color: #e9ecef;
            text-decoration: none;
            color: #212529;
        }

    .btn-delete {
        background-color: #ff4b2b;
        color: white;
        box-shadow: 0 4px 15px rgba(255, 75, 43, 0.3);
    }

        .btn-delete:hover {
            background-color: #e63e1f;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 75, 43, 0.4);
        }
</style>

<div class="center-lock-container">
    <div class="delete-card">

        <div class="card-header">
            <h3>SİLME İŞLEMİ</h3>
            <p>Bu kullanıcıyı kalıcı olarak silmek üzeresiniz.</p>
        </div>

        <div class="card-body">

            <div class="info-row">
                <span class="info-label">Ad</span>
                <span class="info-value">@Html.DisplayFor(model => model.Name)</span>
            </div>

            <div class="info-row">
                <span class="info-label">Soyad</span>
                <span class="info-value">@Html.DisplayFor(model => model.Surname)</span>
            </div>

            <div class="info-row">
                <span class="info-label">Telefon</span>
                <span class="info-value">
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        @Html.DisplayFor(model => model.Phone)
                    }
                    else
                    {
                        <span style="color:#ccc;">-</span>
                    }
                </span>
            </div>

            <div class="info-row">
                <span class="info-label">E-posta</span>
                <span class="info-value">@Html.DisplayFor(model => model.Email)</span>
            </div>

            <div class="info-row">
                <span class="info-label">Rol</span>
                <span class="info-value">@Html.DisplayFor(model => model.Role)</span>
            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="actions">
                    <a href="@Url.Action("Index")" class="btn-action btn-cancel">Vazgeç</a>
                    <button type="submit" class="btn-action btn-delete">Sil</button>
                </div>
            }
        </div>
    </div>
</div>