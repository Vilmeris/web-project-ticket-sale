@model IEnumerable<Web_Programming_Project.Models.User>

@{
    ViewBag.Title = "Kullanıcı Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top: 40px; margin-bottom: 40px;">

    <div class="row mb-4" style="border-bottom: 2px solid #333; padding-bottom: 10px;">
        <div class="col-md-8">
            <h2 style="text-align: left; font-weight: bold;">Kullanıcı Listesi</h2>
        </div>
        <div class="col-md-4 text-right" style="text-align: right;">
            @Html.ActionLink("+ Yeni Kullanıcı Ekle", "Create", null, new { @class = "btn btn-primary" })
        </div>
    </div>

    <div class="user-list">
        @foreach (var item in Model)
        {
            <div class="user-item" style="padding: 10px 0;">
                <div class="row align-items-center">

                    <div class="col-md-4" style="text-align: left;">
                        <h4 style="margin: 0; color: #333;">
                            @Html.DisplayFor(modelItem => item.Name) @Html.DisplayFor(modelItem => item.Surname)
                        </h4>
                        <div style="margin-top: 5px;">
                            @if (item.Role == "Admin")
                            {
                                <span style="background-color: #dc3545; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px;">Yönetici</span>
                            }
                            else
                            {
                                <span style="background-color: #28a745; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px;">Üye</span>
                            }
                        </div>
                    </div>

                    <div class="col-md-5" style="text-align: left;">
                        <p style="margin: 0;"><strong>E-Posta:</strong> @Html.DisplayFor(modelItem => item.Email)</p>
                        <p style="margin: 0;"><strong>Telefon:</strong> @Html.DisplayFor(modelItem => item.Phone)</p>
                    </div>

                    <div class="col-md-3" style="text-align: right;">
                        @Html.ActionLink("Düzenle", "Edit", new { id = item.UserId }, new { @class = "btn btn-sm btn-warning", style = "margin-right:5px;" })
                        @Html.ActionLink("Sil", "Delete", new { id = item.UserId }, new { @class = "btn btn-sm btn-danger" })
                    </div>
                </div>
            </div>

            <hr style="border-top: 1px solid #ccc;" />
        }
    </div>

</div>