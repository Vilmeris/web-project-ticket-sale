@model IEnumerable<Web_Programming_Project.Models.User>

@{
    ViewBag.Title = "Kullanıcı Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 1. ÜST BAŞLIK ALANI */
    .top-header-section {
        background-color: #1e2024;
        color: white;
        padding: 30px 20px;
        text-align: center;
        border-radius: 0 0 15px 15px;
        margin-bottom: 30px;
        width: 100%;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .header-title {
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 5px;
        color: #fff;
    }

    .header-subtitle {
        color: #aaa;
        font-size: 0.9rem;
        display: block;
        margin-bottom: 20px;
    }

    .btn-add-new {
        background-color: #fff;
        color: #333;
        font-weight: 700;
        padding: 10px 30px;
        border-radius: 50px;
        text-decoration: none;
        transition: transform 0.2s ease;
        display: inline-block;
    }

        .btn-add-new:hover {
            transform: scale(1.05);
            background-color: #f0f0f0;
            color: #000;
            text-decoration: none;
        }

    /* 2. GRID YAPISI */
    .custom-user-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 15px;
        padding: 0 20px;
        width: 100%;
    }

    @@media (max-width: 1800px) {
        .custom-user-grid {
            grid-template-columns: repeat(6, 1fr);
        }
    }

    @@media (max-width: 1400px) {
        .custom-user-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    @@media (max-width: 992px) {
        .custom-user-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .custom-user-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .custom-user-grid {
            grid-template-columns: repeat(1, 1fr);
        }
    }


    /* 3. KULLANICI KARTI TASARIMI */
    .user-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        padding: 15px;
        text-align: center;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        min-width: 0;
    }

        .user-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            border-color: #ccc;
        }

    /* Avatar */
    .user-avatar {
        width: 50px;
        height: 50px;
        background-color: #f1f3f5;
        color: #495057;
        font-size: 20px;
        font-weight: bold;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px auto;
    }

    .user-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Rol Etiketleri */
    .badge-role {
        font-size: 0.65rem;
        padding: 2px 8px;
        border-radius: 12px;
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 8px;
        display: inline-block;
    }

    .role-admin {
        background-color: #ffebee;
        color: #c62828;
    }

    .role-user {
        background-color: #e8f5e9;
        color: #2e7d32;
    }

    /* Bilgi Satırları */
    .user-info {
        font-size: 0.75rem;
        color: #666;
        margin-bottom: 3px;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .user-info i {
            margin-right: 3px;
            color: #999;
        }

    /* Buton Grubu */
    .card-actions {
        margin-top: 10px;
        display: flex;
        gap: 3px;
    }

    .btn-action {
        flex: 1;
        padding: 4px 0;
        font-size: 0.75rem;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    /* Görseldeki sorunu çözmek için renkleri sabitliyoruz */
    .btn-edit {
        background-color: #fff3cd !important;
        color: #856404 !important;
    }

        .btn-edit:hover {
            background-color: #ffeeba !important;
        }

    .btn-delete {
        background-color: #f8d7da !important;
        color: #721c24 !important;
    }

        .btn-delete:hover {
            background-color: #f5c6cb !important;
        }
</style>


<div class="container-fluid p-0">
    <div class="top-header-section">
        <h2 class="header-title">Kullanıcı Listesi</h2>
        <span class="header-subtitle">Sistemde kayıtlı toplam @Model.Count() kullanıcı bulunmaktadır.</span>

        <a href="@Url.Action("Create")" class="btn-add-new">
            <i class="bi bi-plus-circle-fill"></i> Yeni Kullanıcı Ekle
        </a>
    </div>
</div>

<div class="container-fluid mb-5">
    <div class="custom-user-grid">
        @foreach (var item in Model)
        {
            <div class="user-card">

                @* Avatar ve İsim *@
                <div>
                    <div class="user-avatar">
                        @(string.IsNullOrEmpty(item.Name) ? "?" : item.Name.Substring(0, 1).ToUpper())
                    </div>

                    <div class="user-name" title="@item.Name @item.Surname">
                        @Html.DisplayFor(modelItem => item.Name) @Html.DisplayFor(modelItem => item.Surname)
                    </div>

                    @if (item.Role == "Admin")
                    {
                        <span class="badge-role role-admin">Yönetici</span>
                    }
                    else
                    {
                        <span class="badge-role role-user">Üye</span>
                    }
                </div>

                @* Bilgiler *@
                <div class="mt-1">
                    <div class="user-info" title="@item.Email">
                        <i class="bi bi-envelope"></i> @item.Email
                    </div>
                    <div class="user-info">
                        <i class="bi bi-telephone"></i> @(string.IsNullOrEmpty(item.Phone) ? "-" : item.Phone)
                    </div>
                    <div class="user-info">
                        <i class="bi bi-wallet2"></i>
                        <span style="color: #28a745; font-weight:bold;">0,00 ₺
                        </span>
                    </div>
                </div>

                @* Aksiyon Butonları *@
                <div class="card-actions">
                    <a href="@Url.Action("Edit", new { id = item.UserId })" class="btn-action btn-edit" title="Düzenle">
                        DÜZENLE
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a href="@Url.Action("Delete", new { id = item.UserId })" class="btn-action btn-delete" title="Sil">
                        SİL
                        <i class="bi bi-trash"></i>
                    </a>
                </div>

            </div>
        }
    </div>
</div>