<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Ticketpair</title>

    @* Genel CSS Dosyaları *@
    <link rel="stylesheet" href="~/Content/mert.css">
    <link rel="stylesheet" href="~/Content/main.css">
    <link rel="stylesheet" href="~/Content/Site.css">
    <link rel="stylesheet" href="~/Content/footer.css">

    @* --- LOADER CSS KODLARI BURAYA EKLENDİ --- *@
<style>
        /* 1. Tüm ekranı kaplayan perde (Wrapper) */
        #global-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: #ffffff; /* Arka planı beyaz yaptım, renkler daha net görünsün diye */
            z-index: 99999;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: opacity 0.5s ease;
        }

        /* 2. Yeni Spinner CSS Kodları */
        .spinner {
            margin: auto;
            width: 50px;
            height: 30px;
            /* İçindeki div'ler float olduğu için kapsayıcıyı hizalamak adına */
            display: inline-block;
        }

        .spinner > div {
            background-color: #195FD2; /* $color-alpha: Mavi */
            height: 100%;
            width: 6px; /* Görünürlüğü artırmak için 2px'i 6px yaptım, istersen düşürebilirsin */
            float: left;
            margin: 0 1px;
            animation: stretch 2s infinite;
            animation-timing-function: cubic-bezier(.62,.28,.23,.99);
        }

        .spinner .r1 { animation-delay: -1s; }
        .spinner .r2 { animation-delay: -.9s; }
        .spinner .r3 { animation-delay: -.8s; }
        .spinner .r4 { animation-delay: -.7s; }
        .spinner .r5 { animation-delay: -.6s; }

        /* Razor uyumlu Keyframes (Çift at işareti */
        @@keyframes stretch {
            0%, 20%, 49% {
                transform: scaleY(0.4);
                background-color: #195FD2; /* Mavi */
            }

            10% {
                transform: scaleY(1.0);
            }

            50%, 70%, 100% {
                transform: scaleY(0.4);
                background-color: #649129; /* $color-beta: Yeşil */
            }

            60% {
                transform: scaleY(1.0);
                background-color: #649129; /* Yeşil */
            }
        }
</style>
    @* --- LOADER CSS BİTİŞ --- *@

    @RenderSection("head", required: false)

</head>

<body id="bodyid">

    @if (User.Identity.IsAuthenticated)
    {
        // Veritabanı bağlamını çağırıyoruz (Admin kontrolü için)
        // Not: Performans için normalde bu kontrol Login aşamasında Session'a atılır ama
        // senin mevcut yapını bozmadan en hızlı böyle çözeriz.
        using (var dbCheck = new Web_Programming_Project.Models.DbPersonal())
        {
            var activeUser = dbCheck.Users.FirstOrDefault(x => x.Email == User.Identity.Name);

            // Eğer kullanıcı varsa VE rolü Admin ise menüyü göster
            if (activeUser != null && activeUser.Role == "Admin")
            {
                <div class="admin-menu-container">
                    <div class="admin-hamburger" id="adminHamburger" onclick="toggleAdminMenu()">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>

                    <div class="admin-dropdown" id="adminDropdown">
                        <div class="admin-title">YÖNETİM PANELİ</div>
                        <ul>
                            <li>
                                <a href="@Url.Action("Index", "Events")">
                                    <i class="bi bi-calendar-event"></i> Etkinlikleri Yönet (Index)
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("Create", "Events")">
                                    <i class="bi bi-plus-circle"></i> Yeni Etkinlik Ekle
                                </a>
                            </li>

                            <li>
                                <a href="@Url.Action("Index", "PersonelManage")">
                                    <i class="bi bi-people"></i> Kullanıcı Yönetimi
                                </a>
                            </li>

                            <li class="separator"></li>

                            <li>
                                <a href="@Url.Action("Index", "Admin")">
                                    <i class="bi bi-speedometer2"></i> Admin Dashboard
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            }
        }
    }



    <div id="global-loader">
        <div class="spinner">
            <div class="r1"></div>
            <div class="r2"></div>
            <div class="r3"></div>
            <div class="r4"></div>
            <div class="r5"></div>
        </div>
    </div>




    <header class="üst-kısım" id="üst-kısımid">
        <div class="logo"><a href="@Url.Action("Index", "Home")" style="color: aliceblue; text-decoration: none;"> Ticketpair </a> </div>

        <div class="sol-butonlar">
            <a href="@Url.Action("Category", "Home", new { id = "Konser" })" class="nav-btn" style="text-decoration:none;">KONSER</a>
            <a href="@Url.Action("Category", "Home", new { id = "Sinema" })" class="nav-btn" style="text-decoration:none;">SİNEMA</a>
            <a href="@Url.Action("Category", "Home", new { id = "Tiyatro" })" class="nav-btn" style="text-decoration:none;">TİYATRO</a>
            <a href="@Url.Action("Category", "Home", new { id = "Spor" })" class="nav-btn" style="text-decoration:none;">SPOR</a>
            <a href="@Url.Action("Category", "Home", new { id = "Festival" })" class="nav-btn" style="text-decoration:none;">FESTİVAL</a>
            <a href="@Url.Action("Index", "Cart")" class="nav-btn" style="text-decoration: none;">SEPETİM</a>
        </div>

        <nav class="sag-nav-grubu">
            <input type="text" placeholder="Bilet ara..." class="search-bar">
            @if (User.Identity.IsAuthenticated)
            {
                <div style="display: inline-flex; align-items: center; gap: 15px;">

                    <span style="color: white; font-weight: 500;">
                        Merhaba, @(Session["NameSurname"] != null ? Session["NameSurname"] : User.Identity.Name)
                    </span>

                    <a href="@Url.Action("Logout", "Security")" class="auth-btn" style="background-color: #dc3545; border-color: #dc3545; text-decoration: none;">
                        Çıkış Yap
                    </a>
                </div>
            }
            else
            {
                <a href="@Url.Action("Login", "Security")" class="auth-btn" style="text-decoration: none;">
                    Giriş / Kaydol
                </a>
            }
            <button id="theme-toggle" class="theme-btn">🌙</button>
        </nav>
    </header>

    @* BURASI, SAYFALARIN KENDİ İÇERİĞİNİN GELECEĞİ YERDİR *@
    <main class="@(ViewBag.GenisSayfa == true ? "container-fluid p-0" : "container")">
        @RenderBody()
    </main>

    <footer class="site-footer" id="footerid">
        <div class="footer-content">
            <div class="footer-left">
                <img id="footer-logo-img" src="~/Content/images/unnamed (1).jpg" alt="Site Logo" class="footer-logo" style="width: 250px; height: 200px;">
                <p>Tel: +90 555 123 45 67</p>
                <p>Email: info@site.com</p>
            </div>

            <div class="footer-center">
                <a href="@Url.Action("About", "Home")" style="color: aliceblue; text-decoration: none;">Hakkımızda</a>
                <a href="@Url.Action("Contact", "Home")" style="color: aliceblue; text-decoration: none;">İletişim</a>
                <a href="#" style="color: aliceblue; text-decoration: none;">Yardım</a>
                <a href="#" style="color: aliceblue; text-decoration: none;">Gizlilik</a>
            </div>

            <div class="footer-right">
                <p>&copy; @DateTime.Now.Year Ticketpair. Tüm hakları saklıdır.</p>
            </div>
        </div>
    </footer>

    @* Genel JavaScript Dosyaları *@
    <script src="~/Scripts/eser.js"></script>
    <script src="~/Scripts/main.js"></script>
    <script src="~/Scripts/leftside.js"></script>

    @* --- LOADER JAVASCRIPT KODLARI (En alta alındı) --- *@
    <script>
        // 1. Sayfa tamamen yüklendiğinde Loader'ı gizle
        window.addEventListener("load", function () {
            var loader = document.getElementById("global-loader");
            if (loader) {
                loader.style.opacity = "0"; // Saydamlaştır
                setTimeout(function () {
                    loader.style.display = "none";
                }, 500);
            }
        });

        // 2. Linklere tıklandığında Loader'ı tekrar göster
        document.addEventListener("DOMContentLoaded", function () {
            var loader = document.getElementById("global-loader");
            var links = document.querySelectorAll("a");

            links.forEach(function (link) {
                link.addEventListener("click", function (e) {
                    var href = link.getAttribute("href");
                    var target = link.getAttribute("target");

                    // Eğer link boş değilse, '#' değilse ve yeni sekmede açılmıyorsa
                    if (href && href !== "#" && href.startsWith("/") && target !== "_blank") {
                        if (loader) {
                            loader.style.display = "flex";
                            setTimeout(() => { loader.style.opacity = "1"; }, 10);
                        }
                    }
                });
            });

            // Form gönderildiğinde de loader çıksın
            var forms = document.querySelectorAll("form");
            forms.forEach(function (form) {
                form.addEventListener("submit", function () {
                    if (loader) {
                        loader.style.display = "flex";
                        setTimeout(() => { loader.style.opacity = "1"; }, 10);
                    }
                });
            });
        });

        // 3. Tarayıcı "Geri" tuşuna basıldığında loader'ın takılı kalmasını önle
        window.addEventListener("pageshow", function (event) {
            if (event.persisted) {
                var loader = document.getElementById("global-loader");
                if (loader) loader.style.display = "none";
            }
        });



    </script>
        

         


    <script>
        function toggleAdminMenu() {
            const container = document.querySelector('.admin-menu-container');
            container.classList.toggle('active');
        }

        // Menü açıkken sayfanın başka yerine tıklanırsa kapansın
        document.addEventListener('click', function (event) {
            const container = document.querySelector('.admin-menu-container');
            const hamburger = document.getElementById('adminHamburger');
            const dropdown = document.getElementById('adminDropdown');

            if (container && container.classList.contains('active')) {
                // Tıklanan yer hamburger veya dropdown değilse kapat
                if (!hamburger.contains(event.target) && !dropdown.contains(event.target)) {
                    container.classList.remove('active');
                }
            }
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Gerekli Elementleri Tanımla
            const themeBtn = document.getElementById("theme-toggle");
            const footerLogo = document.getElementById("footer-logo-img"); // Footer Logosunu Seçiyoruz

            // CSS'te [data-theme] ile renk değiştiren tüm ID'leri buraya yazıyoruz
            const themeElementIds = [
                "üst-kısımid",
                "footerid",
                "leftid",
                "rightid",
                "event-card1",
                "event-card2",
                "event-card3",
                "event-card4",
                "event-card5"
            ];

            // 2. Kaydedilmiş Temayı Kontrol Et (Yoksa 'light' varsay)
            const currentTheme = localStorage.getItem("theme") || "light";

            // Sayfa açılır açılmaz temayı uygula
            applyTheme(currentTheme);

            // 3. Butona Tıklama Olayı
            if (themeBtn) {
                themeBtn.addEventListener("click", () => {
                    // Şu anki mod dark ise light yap, değilse dark yap
                    const newTheme = document.body.classList.contains("dark-mode") ? "light" : "dark";
                    applyTheme(newTheme);
                });
            }

            // --- TEMA UYGULAMA FONKSİYONU ---
            function applyTheme(theme) {
                // A) Body sınıfını ayarla (Genel arkaplan ve butonlar için)
                if (theme === "dark") {
                    document.body.classList.add("dark-mode");
                    if (themeBtn) themeBtn.textContent = "☀️";
                } else {
                    document.body.classList.remove("dark-mode");
                    if (themeBtn) themeBtn.textContent = "🌙";
                }

                // B) Özel ID'lere data-theme özelliğini ekle (Header, Footer, Kartlar için)
                themeElementIds.forEach(id => {
                    const el = document.getElementById(id);
                    if (el) {
                        el.setAttribute("data-theme", theme);
                    }
                });

                // C) FOOTER LOGOSUNU DEĞİŞTİR (BURASI EKSİKTİ, EKLENDİ)
                if (footerLogo) {
                    if (theme === "dark") {
                        // Karanlık modda görünecek logo (Elinizde varsa dark logo yolunu yazın, yoksa aynısı kalabilir)
                        // Örnek: footerLogo.src = "/Content/images/logo-dark.png";
                        footerLogo.src = "/Content/images/unnamed (1).jpg";
                    } else {
                        // Aydınlık modda görünecek logo (Senin orijinal logon)
                        footerLogo.src = "/Content/images/unnamed (2).jpg";
                    }
                }

                // D) Seçimi Tarayıcı Hafızasına Kaydet
                localStorage.setItem("theme", theme);
            }
        });
    </script>


    @RenderSection("scripts", required: false)

</body>
</html>